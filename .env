# ============================================
# Docker Compose Configuration
# ============================================

# Network configuration
DOCKER_NETWORK=user-services-network

# ============================================
# User Service Configuration
# ============================================
USER_SERVICE_NAME=user-service
USER_SERVICE_PORT=8080
USER_CONTAINER_PORT=8080
USER_SERVICE_HOSTNAME=user
USER_ASPNETCORE_URLS=http://+:8080
USER_ASPNETCORE_ENVIRONMENT=Development

# ============================================
# Authorization Service Configuration
# ============================================
AUTHORIZATION_SERVICE_NAME=authorization-service
AUTHORIZATION_SERVICE_PORT=8081
AUTHORIZATION_CONTAINER_PORT=8081
AUTHORIZATION_SERVICE_HOSTNAME=authorization
AUTHORIZATION_ASPNETCORE_URLS=http://+:8081
AUTHORIZATION_ASPNETCORE_ENVIRONMENT=Development

# ============================================
# Grafana Alloy Configuration
# ============================================
ALLOY_SERVICE_NAME=alloy
ALLOY_PORT=4317
ALLOY_CONTAINER_PORT=4317
ALLOY_SERVICE_HOSTNAME=alloy
ALLOY_WEB_PORT=12345
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317

# ============================================
# Mimir Configuration (Metrics Storage)
# ============================================
MIMIR_SERVICE_NAME=mimir
MIMIR_PORT=9009
MIMIR_CONTAINER_PORT=9009
MIMIR_SERVICE_HOSTNAME=mimir

# ============================================
# Grafana Tempo Configuration
# ============================================
TEMPO_SERVICE_NAME=tempo
TEMPO_PORT=3200
TEMPO_CONTAINER_PORT=3200
TEMPO_SERVICE_HOSTNAME=tempo

# ============================================
# Grafana Loki Configuration
# ============================================
LOKI_SERVICE_NAME=loki
LOKI_PORT=3100
LOKI_CONTAINER_PORT=3100
LOKI_SERVICE_HOSTNAME=loki

# ============================================
# Grafana Configuration
# ============================================
GRAFANA_SERVICE_NAME=grafana
GRAFANA_PORT=3000
GRAFANA_CONTAINER_PORT=3000
GRAFANA_SERVICE_HOSTNAME=grafana
GRAFANA_ADMIN_ENABLED=true
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ORG_ROLE=Admin

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=Information
DOTNET_RUNNING_IN_CONTAINER=true

# ============================================
# Inter-service Communication URLs
# ============================================
# User Service calling Authorization Service
AUTHORIZATION_SERVICE_URL=http://authorization:8081
USER_SERVICE_URL=http://user:8080

# ============================================
# Build Configuration
# ============================================
BUILD_CONFIGURATION=Release
DOTNET_VERSION=10.0

